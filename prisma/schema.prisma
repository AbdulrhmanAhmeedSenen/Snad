generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  email               String    @unique
  status              String    @default("active")
  plan                String    @default("free")
  maintenanceMode     Boolean   @default(false)
  features            String?   // JSON string of enabled feature flags
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  branches            Branch[]
  users               User[]
  roles               Role[]
  auditLogs           AuditLog[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  leads               Lead[]
  customers           Customer[]
  opportunities       Opportunity[]
  tasks               Task[]
  quotations          Quotation[]
  vendors             Vendor[]
  purchaseOrders      PurchaseOrder[]
  inventoryItems      InventoryItem[]
  employees           Employee[]
  attendanceRecords   AttendanceRecord[]
  payrollRuns         PayrollRun[]
  accounts            Account[]
  journalEntries      JournalEntry[]
  invoices            Invoice[]
  payments            Payment[]
  dashboardMetrics    DashboardMetric[]
  aiInsights          AIInsight[]
  products            Product[]
  orders              Order[]
  posDevices          POSDevice[]
  communicationLogs   CommunicationLog[]
  webhookSubscriptions WebhookSubscription[]
  @@map("tenants")
}

model Branch {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  code          String
  address       String?
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments   Department[]
  users         User[]
  posDevices    POSDevice[]
  @@index([tenantId])
  @@map("branches")
}

model Department {
  id            String    @id @default(cuid())
  branchId      String
  name          String
  code          String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  branch        Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  users         User[]
  employees     Employee[]
  @@index([branchId])
  @@map("departments")
}

model User {
  id                  String              @id @default(cuid())
  tenantId            String
  branchId            String?
  departmentId        String?
  email               String              @unique
  name                String
  isActive            Boolean             @default(true)
  isDeleted           Boolean             @default(false)
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department          Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  userRoles           UserRole[]
  auditLogs           AuditLog[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  assignedLeads       Lead[]
  assignedCustomers   Customer[]
  assignedOpportunities Opportunity[]
  assignedTasks       Task[]
  quotations          Quotation[]
  requestedApprovals  ApprovalRequest[]   @relation("RequesterApprovals")
  approvedApprovals   ApprovalRequest[]   @relation("ApproverApprovals")
  employees           Employee[]
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  isSystem      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles     UserRole[]
  permissions   RolePermission[]
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String?
  createdAt     DateTime  @default(now())
  rolePermissions RolePermission[]
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
  @@map("user_roles")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  action      String
  entity      String
  entityId    String?
  oldValue    String?
  newValue    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  action      String
  description String
  metadata    String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Notification {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Lead {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  email         String?
  phone         String?
  company       String?
  status        String    @default("new")
  source        String?
  assignedUserId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser  User?     @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([status])
  @@map("leads")
}

model Customer {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  type          String    @default("company")
  email         String?
  phone         String?
  address       String?
  creditLimit   Float     @default(0)
  assignedUserId String?
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser  User?     @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]
  quotations    Quotation[]
  invoices      Invoice[]
  payments      Payment[]
  orders        Order[]
  @@index([tenantId])
  @@map("customers")
}

model Opportunity {
  id                String    @id @default(cuid())
  tenantId          String
  customerId        String
  name              String
  stage             String    @default("prospecting")
  value             Float     @default(0)
  currency          String    @default("USD")
  expectedCloseDate DateTime?
  assignedUserId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedUser      User?     @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  quotations        Quotation[]
  @@index([tenantId])
  @@index([stage])
  @@map("opportunities")
}

model Task {
  id                String    @id @default(cuid())
  tenantId          String
  assignedUserId    String
  relatedEntityId   String?
  relatedEntityType String?
  title             String
  description       String?
  dueDate           DateTime?
  status            String    @default("pending")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser      User      @relation(fields: [assignedUserId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([assignedUserId])
  @@index([status])
  @@map("tasks")
}

model Quotation {
  id                String    @id @default(cuid())
  tenantId          String
  customerId        String
  opportunityId     String?
  quoteNumber       String    @unique
  title             String
  status            String    @default("draft")
  totalAmount       Float     @default(0)
  currency          String    @default("USD")
  validUntil        DateTime?
  notes             String?
  createdByUserId   String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer          Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  opportunity       Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  createdByUser     User        @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  items             QuotationItem[]
  approvals         ApprovalRequest[]
  @@index([tenantId])
  @@index([status])
  @@index([quoteNumber])
  @@map("quotations")
}

model QuotationItem {
  id            String    @id @default(cuid())
  quotationId   String
  description   String
  quantity      Float     @default(1)
  unitPrice     Float
  discountPercent Float   @default(0)
  taxPercent    Float     @default(0)
  total         Float
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  @@index([quotationId])
  @@map("quotation_items")
}

model ApprovalRequest {
  id                String    @id @default(cuid())
  quotationId       String
  requesterUserId   String
  approverUserId    String
  status            String    @default("pending")
  comments          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  quotation         Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  requesterUser     User      @relation("RequesterApprovals", fields: [requesterUserId], references: [id], onDelete: Cascade)
  approverUser      User      @relation("ApproverApprovals", fields: [approverUserId], references: [id], onDelete: Cascade)
  @@index([quotationId])
  @@index([status])
  @@map("approval_requests")
}

model Vendor {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  contactEmail  String?
  contactPhone  String?
  address       String?
  taxId         String?
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  invoices      Invoice[]
  payments      Payment[]
  @@index([tenantId])
  @@map("vendors")
}

model PurchaseOrder {
  id            String    @id @default(cuid())
  tenantId      String
  vendorId      String
  poNumber      String    @unique
  status        String    @default("draft")
  totalAmount   Float     @default(0)
  currency      String    @default("USD")
  expectedDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor        Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items         PurchaseOrderItem[]
  @@index([tenantId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id            String    @id @default(cuid())
  purchaseOrderId String
  description   String
  quantity      Float     @default(1)
  unitPrice     Float
  total         Float
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model InventoryItem {
  id            String    @id @default(cuid())
  tenantId      String
  sku           String    @unique
  name          String
  quantity      Float     @default(0)
  unitCost      Float     @default(0)
  reorderLevel  Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([sku])
  @@map("inventory_items")
}

model Employee {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String?
  departmentId  String?
  firstName     String
  lastName      String
  jobTitle      String
  hireDate      DateTime
  salary        Float     @default(0)
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  department    Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  attendance    AttendanceRecord[]
  payroll       PayrollRun[]
  @@index([tenantId])
  @@index([status])
  @@map("employees")
}

model AttendanceRecord {
  id            String    @id @default(cuid())
  tenantId      String
  employeeId    String
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  status        String    @default("present")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([employeeId])
  @@index([date])
  @@map("attendance_records")
}

model PayrollRun {
  id            String    @id @default(cuid())
  tenantId      String
  employeeId    String
  periodStart   DateTime
  periodEnd     DateTime
  baseSalary    Float
  deductions    Float     @default(0)
  bonuses       Float     @default(0)
  netPay        Float
  status        String    @default("draft")
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
  @@map("payroll_runs")
}

model Account {
  id            String    @id @default(cuid())
  tenantId      String
  code          String    @unique
  name          String
  type          String
  balance       Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalLines  JournalEntryLine[]
  @@index([tenantId])
  @@map("accounts")
}

model JournalEntry {
  id            String    @id @default(cuid())
  tenantId      String
  date          DateTime  @default(now())
  description   String
  status        String    @default("draft")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines         JournalEntryLine[]
  @@index([tenantId])
  @@map("journal_entries")
}

model JournalEntryLine {
  id                String        @id @default(cuid())
  journalEntryId    String
  accountId         String
  debit             Float         @default(0)
  credit            Float         @default(0)
  description       String?
  journalEntry      JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account           Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  @@index([journalEntryId])
  @@map("journal_entry_lines")
}

model Invoice {
  id            String    @id @default(cuid())
  tenantId      String
  customerId    String?
  vendorId      String?
  type          String
  invoiceNumber String    @unique
  date          DateTime  @default(now())
  dueDate       DateTime?
  totalAmount   Float     @default(0)
  status        String    @default("draft")
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vendor        Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  payments      Payment[]
  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

model Payment {
  id            String    @id @default(cuid())
  tenantId      String
  invoiceId     String?
  customerId    String?
  vendorId      String?
  amount        Float
  date          DateTime  @default(now())
  method        String    @default("cash")
  status        String    @default("completed")
  createdAt     DateTime  @default(now())
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice       Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vendor        Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([invoiceId])
  @@index([customerId])
  @@index([vendorId])
  @@map("payments")
}

model DashboardMetric {
  id          String   @id @default(cuid())
  tenantId    String
  metricType  String
  value       Float
  period      String
  date        DateTime
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([metricType])
  @@index([date])
  @@map("dashboard_metrics")
}

model AIInsight {
  id          String   @id @default(cuid())
  tenantId    String
  category    String
  title       String
  description String
  confidence  Float    @default(0.0)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([category])
  @@map("ai_insights")
}

model Product {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  sku           String    @unique
  price         Float
  stock         Float     @default(0)
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  @@index([tenantId])
  @@index([isActive])
  @@map("products")
}

model Order {
  id            String    @id @default(cuid())
  tenantId      String
  customerId    String?
  type          String    @default("ecommerce")
  status        String    @default("pending")
  totalAmount   Float     @default(0)
  currency      String    @default("USD")
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  @@index([tenantId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  productId     String?
  productName   String
  quantity      Float     @default(1)
  unitPrice     Float
  total         Float
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  @@index([orderId])
  @@map("order_items")
}

model POSDevice {
  id            String    @id @default(cuid())
  tenantId      String
  branchId      String
  deviceCode    String    @unique
  status        String    @default("active")
  lastPing      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([branchId])
  @@map("pos_devices")
}

model CommunicationLog {
  id          String   @id @default(cuid())
  tenantId    String
  type        String
  recipient   String
  subject     String?
  content     String
  status      String   @default("pending")
  metadata    String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@map("communication_logs")
}

model WebhookSubscription {
  id          String   @id @default(cuid())
  tenantId    String
  url         String
  events      String
  isActive    Boolean  @default(true)
  secret      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([isActive])
  @@map("webhook_subscriptions")
}